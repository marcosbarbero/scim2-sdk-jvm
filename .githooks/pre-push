#!/bin/bash

# Pre-push hook for SCIM 2.0 SDK
# Catches formatting, licensing, and compilation issues before pushing.
#
# Auto-installed by git-build-hook-maven-plugin on first build.
# Manual install: cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# To bypass (emergency only): git push --no-verify

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Running pre-push checks...${NC}"
echo -e "${BLUE}========================================${NC}"

# Source SDKMAN if available
if [ -f "$HOME/.sdkman/bin/sdkman-init.sh" ]; then
    source "$HOME/.sdkman/bin/sdkman-init.sh"
fi

# Apply .sdkmanrc if present
if [ -f ".sdkmanrc" ] && command -v sdk &> /dev/null; then
    sdk env install 2>/dev/null || true
fi

# Ensure Java is available
if ! command -v java &> /dev/null; then
    echo -e "${RED}Java not found. Please install Java 25.${NC}"
    exit 1
fi

# Determine base ref for diffing changed files
BASE_REF="origin/main"
if ! git rev-parse --verify "${BASE_REF}" &>/dev/null; then
    BASE_REF="HEAD~1"
fi

# ============================================================
# Step 1/3: License headers
# ============================================================
echo -e "\n${BLUE}Step 1/3: Checking license headers...${NC}"
if mvn license:check -T1C -q 2>/dev/null; then
    echo -e "${GREEN}License check passed${NC}"
else
    echo -e "${RED}License check failed${NC}"
    echo -e "${YELLOW}   Run: mvn license:format${NC}"
    exit 1
fi

# ============================================================
# Step 2/3: Code formatting
# ============================================================
echo -e "\n${BLUE}Step 2/3: Checking code formatting...${NC}"
if mvn spotless:check -T1C -q 2>/dev/null; then
    echo -e "${GREEN}Formatting check passed${NC}"
else
    echo -e "${RED}Formatting check failed${NC}"
    echo -e "${YELLOW}   Run: mvn spotless:apply${NC}"
    exit 1
fi

# ============================================================
# Step 3/3: Build changed modules
# ============================================================
echo -e "\n${BLUE}Step 3/3: Building changed modules...${NC}"

detect_changed_modules() {
    local changed_files
    changed_files=$(git diff --name-only "${BASE_REF}...HEAD" 2>/dev/null) || {
        changed_files=$(git diff --name-only HEAD~1 HEAD)
    }

    if [ -z "$changed_files" ]; then
        return
    fi

    # If root pom.xml changed, full build
    if echo "$changed_files" | grep -qE '^pom\.xml$'; then
        echo "ROOT"
        return
    fi

    echo "$changed_files" | while IFS= read -r file; do
        dir=$(dirname "$file")
        while [ "$dir" != "." ]; do
            if [ -f "$dir/pom.xml" ]; then
                echo "$dir"
                break
            fi
            dir=$(dirname "$dir")
        done
    done | sort -u
}

CHANGED_MODULES=$(detect_changed_modules)

if [ -z "$CHANGED_MODULES" ]; then
    echo -e "${GREEN}No Maven module changes detected, skipping build${NC}"
elif echo "$CHANGED_MODULES" | grep -q "^ROOT$"; then
    echo -e "${YELLOW}Root pom.xml changed, running full reactor build${NC}"
    if mvn compile test -T1C -q; then
        echo -e "${GREEN}Full build passed${NC}"
    else
        echo -e "${RED}Full build failed${NC}"
        exit 1
    fi
else
    MODULE_LIST=$(echo "$CHANGED_MODULES" | paste -sd ',' -)
    echo -e "${BLUE}Changed modules:${NC}"
    echo "$CHANGED_MODULES" | while IFS= read -r mod; do
        echo -e "${BLUE}  - ${mod}${NC}"
    done

    if mvn compile test -pl "${MODULE_LIST}" -am -T1C -q; then
        echo -e "${GREEN}Build passed${NC}"
    else
        echo -e "${RED}Build failed${NC}"
        exit 1
    fi
fi

echo -e "\n${GREEN}========================================${NC}"
echo -e "${GREEN}All pre-push checks passed!${NC}"
echo -e "${GREEN}========================================${NC}"

exit 0
